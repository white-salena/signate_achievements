   "source": [
    "import pandas as pd\n",
    "\n",
    "# データフレームを読み込む\n",
    "data = pd.read_csv(\"train.csv\")\n",
    "\n",
    "# datetime列を日付型に変換\n",
    "data['datetime'] = pd.to_datetime(data['datetime'])\n",
    "\n",
    "# 曜日を数値として取得して新しい列を追加\n",
    "data['weekday_numeric'] = data['datetime'].dt.dayofweek\n",
    "\n",
    "# 結果を表示\n",
    "print(data)"
   ]
